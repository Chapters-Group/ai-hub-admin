# Database
DATABASE_URL=postgresql+asyncpg://chapters:chapters@localhost:5432/chapters_admin

# Auth
SECRET_KEY=change-me-to-a-random-secret-key
ADMIN_EMAIL=admin@chaptersgroup.com
ADMIN_PASSWORD=changeme123

# Encryption key for API keys stored in DB
ENCRYPTION_KEY=change-me-to-a-32-byte-base64-key

# CORS allowed origins (comma-separated, override for production)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Health check interval in seconds
HEALTH_CHECK_INTERVAL=60
